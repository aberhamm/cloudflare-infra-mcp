{
  "name": "cloudflare-infra-mcp",
  "version": "0.1.0",
  "description": "MCP server for Cloudflare infrastructure operations — DNS, WAF, tunnels, and Zero Trust Access",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cloudflare-infra-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "msw": "^2.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "cloudflare",
    "dns",
    "waf",
    "tunnels",
    "infrastructure",
    "zero-trust"
  ]
}
